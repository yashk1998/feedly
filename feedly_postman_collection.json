{
  "info": {
    "name": "Syncd API",
    "description": "Complete API collection for Syncd — AI-powered RSS feed reader. All authenticated endpoints require a valid NextAuth session token.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{session_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "session_token",
      "value": "",
      "type": "string",
      "description": "NextAuth session token — copy from browser cookies (next-auth.session-token)"
    },
    {
      "key": "cron_secret",
      "value": "",
      "type": "string",
      "description": "CRON_SECRET from .env for triggering sync"
    }
  ],
