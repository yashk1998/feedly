# Database
DATABASE_URL="postgresql://user:password@localhost:5432/syncd"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# OAuth Providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Redis
REDIS_URL="redis://localhost:6379"

# AI Provider — configure at least one
# Azure OpenAI (priority 1)
AZURE_OPENAI_ENDPOINT=""
AZURE_OPENAI_KEY=""
AZURE_OPENAI_DEPLOYMENT="gpt-4o"
AZURE_OPENAI_DEPLOYMENT_VERSION="2024-02-15-preview"
AZURE_OPENAI_EMBEDDING_DEPLOYMENT="text-embedding-ada-002"  # for topic clustering

# AWS Bedrock (priority 2)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_BEDROCK_REGION="us-east-1"
AWS_BEDROCK_MODEL="anthropic.claude-3-haiku-20240307-v1:0"

# Gemini (priority 3)
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash-lite"

# OpenAI Direct (priority 4)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"  # for topic clustering

# Razorpay
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
